{
  "$schema": "https://github.com/qwc-services/qwc-fulltext-search-service/raw/master/schemas/qwc-search-service.json",
  "service": "search",
  "config": {
    "db_url": "postgresql:///?service=TOMs_Test",
    "search_backend": "solr",
    "search_result_limit": 50,
    "solr_service_url": "http://qwc-solr:8983/solr/gdi/select"
  },
  "resources": {
    "facets": [
      {
        "name": "Bays",
        "filter_word": "Bay",
        "table_name": "toms.\"Bays\"",
        "geometry_column": "geom",
        "search_id_col": "ogc_fid"
      },
      {
        "name": "Proposals",
        "filter_word": "Proposal",
        "table_name": "toms.\"Proposals\"",
        "geometry_column": "geom",
        "search_id_col": "ogc_fid"
      }
    ]
  }
}